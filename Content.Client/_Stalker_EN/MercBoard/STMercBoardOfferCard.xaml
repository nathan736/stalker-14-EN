<PanelContainer xmlns="https://spacestation14.io"
                xmlns:merc="clr-namespace:Content.Client._Stalker_EN.MercBoard"
                HorizontalExpand="True"
                Margin="0">

    <BoxContainer Name="CardContent" Orientation="Vertical" Margin="6">

        <!-- Header: faction icon + poster name + offer ID -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 0 0 2">
            <TextureRect Name="FactionIcon" MinSize="20 20" Stretch="KeepAspectCentered" Margin="0 0 4 0" Visible="False"/>
            <Label Name="PosterNameLabel" HorizontalExpand="True"/>
            <Label Name="OfferIdLabel" StyleClasses="LabelSubText" Align="Right"/>
        </BoxContainer>

        <!-- Elapsed time -->
        <Label Name="TimeLabel" StyleClasses="LabelSubText" Margin="0 0 0 2"/>

        <!-- Price -->
        <Label Name="PriceLabel" Margin="0 0 0 1"/>

        <!-- Duration -->
        <Label Name="DurationLabel" Margin="0 0 0 2"/>

        <!-- Description -->
        <RichTextLabel Name="DescriptionLabel" HorizontalExpand="True" Margin="0 2 0 4"/>

        <!-- Action button (Contact or Withdraw) -->
        <Button Name="ActionButton" HorizontalExpand="True"/>

    </BoxContainer>

</PanelContainer>
